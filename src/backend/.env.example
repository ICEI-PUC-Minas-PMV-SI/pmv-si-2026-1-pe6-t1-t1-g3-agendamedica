# Database (Docker — valores definidos em docker-compose.yml)
DATABASE_URL=postgresql://medhub:medhub@localhost:5432/medhub

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# SMTP (e.g. Mailtrap for development)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=no-reply@medhub.app

# Expo Push Notifications (optional in development)
# EXPO_ACCESS_TOKEN=your_expo_access_token
