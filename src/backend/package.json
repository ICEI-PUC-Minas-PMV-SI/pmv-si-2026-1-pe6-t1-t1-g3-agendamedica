    "expo-server-sdk": "^3.13.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "jest": "^30.3.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.29.1"
