  "version": "1.0.0",
  "description": "MedHub — Backend API (Node.js · Express · TypeScript · Prisma)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
